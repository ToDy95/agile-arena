{
  "name": "agile-arena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "check": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm build",
    "clean": "command -v rimraf >/dev/null 2>&1 && rimraf .next coverage playwright-report test-results .turbo .vitest tsconfig.tsbuildinfo || rm -rf .next coverage playwright-report test-results .turbo .vitest tsconfig.tsbuildinfo",
    "clean:next": "command -v rimraf >/dev/null 2>&1 && rimraf .next || rm -rf .next",
    "clean:modules": "command -v rimraf >/dev/null 2>&1 && rimraf node_modules || rm -rf node_modules",
    "clean:install": "pnpm clean && pnpm clean:modules && (command -v rimraf >/dev/null 2>&1 && rimraf package-lock.json yarn.lock bun.lockb || rm -f package-lock.json yarn.lock bun.lockb) && pnpm install",
    "reset": "pnpm clean:install",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,json,jsonc,css,md}": "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@liveblocks/client": "^3.15.5",
    "@liveblocks/node": "^3.15.5",
    "@liveblocks/react": "^3.15.5",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@next/env": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
